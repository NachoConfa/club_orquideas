# ConfiguraciA3n del servidor
PORT=3001
NODE_ENV=development

# URL del frontend
FRONTEND_URL=http://localhost:5173

# Supabase
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=tu_clave_anon_publica

# Cloudflare Turnstile
# Desarrollo local sin captcha:
VITE_ENABLE_CAPTCHA=false
VITE_TURNSTILE_SITE_KEY=your_turnstile_site_key

# Para probar captcha en local:
# VITE_ENABLE_CAPTCHA=true
# VITE_TURNSTILE_SITE_KEY=clave_publica_de_turnstile
#
# Para producción:
# VITE_ENABLE_CAPTCHA=true
# VITE_TURNSTILE_SITE_KEY=clave_publica_de_produccion
#
# Hostnames a permitir en Cloudflare Turnstile si usas captcha:
# localhost
# 127.0.0.1
# dominio-real.com
# www.dominio-real.com

# Backend / Supabase Edge Function only. Do not expose this with VITE_.
# TURNSTILE_SECRET_KEY=tu_secret_key_privada

# ConfiguraciA3n de base de datos (opcional)
# DATABASE_URL=postgresql://user:password@localhost:5432/orchid_club
